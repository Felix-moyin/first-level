// Quick Buck - Accordion
document.addEventListener('DOMContentLoaded', function () {
  const accordionHeaders = document.querySelectorAll(
    '.quick-buck-accordion-header'
  )
  accordionHeaders.forEach((header) => {
    header.addEventListener('click', toggleAccordion)
    header.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        toggleAccordion.call(header, e)
      }
    })
  })

  function toggleAccordion(event) {
    const content = this.nextElementSibling
    const button = this.querySelector('.quick-buck-accordion-button')
    const isExpanded = button.getAttribute('aria-expanded') === 'true'

    // Toggle the current section
    button.setAttribute('aria-expanded', !isExpanded)
    content.classList.toggle('open', !isExpanded)

    // Optionally, close other sections (for exclusive accordion behavior)
    accordionHeaders.forEach((otherHeader) => {
      if (otherHeader !== this) {
        const otherContent = otherHeader.nextElementSibling
        const otherButton = otherHeader.querySelector(
          '.quick-buck-accordion-button'
        )
        otherButton.setAttribute('aria-expanded', 'false')
        otherContent.classList.remove('open')
      }
    })
  }

  // Adding keyboard accessibility for accordion
  // const accordionContainer = document.getElementById('quickBuckAcordion')
  const accordionContainer = document.getElementsByClassName(
    'bullet-loan-accordion'
  )[0]
  accordionContainer.addEventListener('keydown', function (event) {
    const activeElement = document.activeElement
    const isAccordionHeader = activeElement.classList.contains(
      'quick-buck-accordion-header'
    )

    if (!isAccordionHeader) return

    switch (event.key) {
      case 'ArrowDown':
        focusNextAccordionHeader(activeElement)
        break
      case 'ArrowUp':
        focusPreviousAccordionHeader(activeElement)
        break
      case 'Home':
        focusFirstAccordionHeader()
        break
      case 'End':
        focusLastAccordionHeader()
        break
      default:
        break
    }
  })

  function focusNextAccordionHeader(currentHeader) {
    const nextHeader = currentHeader.nextElementSibling.nextElementSibling
    if (nextHeader) {
      nextHeader.focus()
    }
  }

  function focusPreviousAccordionHeader(currentHeader) {
    const previousHeader =
      currentHeader.previousElementSibling.previousElementSibling
    if (previousHeader) {
      previousHeader.focus()
    }
  }

  function focusFirstAccordionHeader() {
    accordionHeaders[0].focus()
  }

  function focusLastAccordionHeader() {
    accordionHeaders[accordionHeaders.length - 1].focus()
  }
})
